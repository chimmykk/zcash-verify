{
  "manifest_version": 3,
  "name": "ZcashVerify",
  "description": "Cryptographic proof-of-balance badges for Zcash on social platforms",
  "version": "1.0.0",
  "permissions": ["storage"],
  "host_permissions": [
    "http://localhost:3000/*"
  ],
  "icons": {
    "48": "icons/badges/badge_holder.png",
    "128": "icons/badges/badge_100zec.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icons/badges/badge_holder.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://x.com/*",
        "https://twitter.com/*",
        "https://forum.zcashcommunity.com/*",
        "https://bsky.app/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/badges/*"],
      "matches": [
        "https://x.com/*",
        "https://twitter.com/*",
        "https://forum.zcashcommunity.com/*",
        "https://bsky.app/*"
      ]
    }
  ]
}
